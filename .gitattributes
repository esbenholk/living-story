# Force LF line endings in the repository for all text files.
# This prevents CRLF/LF conflicts between Windows dev machines
# and Linux deploy targets (Railway, Vercel, Heroku).

* text=auto eol=lf

# Explicitly LF
*.js        eol=lf
*.jsx       eol=lf
*.ts        eol=lf
*.tsx       eol=lf
*.json      eol=lf
*.md        eol=lf
*.yml       eol=lf
*.yaml      eol=lf
*.toml      eol=lf
*.css       eol=lf
*.html      eol=lf
*.svg       eol=lf
*.py        eol=lf
*.txt       eol=lf
*.sh        eol=lf
*.prisma    eol=lf
Procfile    eol=lf

# Binary files — no line ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.caffemodel binary
*.onnx      binary